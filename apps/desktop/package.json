{
  "name": "@gt-quranreader/desktop",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "SalehGNUTUX",
    "email": "gnutux.arabic@gmail.com",
    "url": "https://github.com/SalehGNUTUX"
  },
  "description": "GT-QURANREADER — عارض القرآن الكريم لسطح المكتب (Electron)",
  "homepage": "https://github.com/SalehGNUTUX/GT-QURANREADER",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"npm:dev\" \"npm:electron:wait\"",
    "electron:wait": "wait-on tcp:5173 && npm run electron:dev",
    "electron:dev": "tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron dist-electron/main.js",
    "build": "tsc --noEmit && vite build && tsc -p electron/tsconfig.json",
    "build:linux": "npm run build && electron-builder --linux",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@gt-quranreader/core": "*",
    "@gt-quranreader/ui": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.gnutux.gt-quranreader",
    "productName": "GT-QURANREADER",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "copyright": "Copyright © 2026 SalehGNUTUX — GPL-3.0-or-later",
    "electronVersion": "33.3.1",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules/**"
    ],
    "extraResources": [
      { "from": "build/icon.png", "to": "icon.png" }
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Education;Education;Languages",
      "synopsis": "Quran Reader with Arabic interface",
      "description": "عارض القرآن الكريم — 4 روايات (ورش/حفص/قالون/الدوري)، 13+ قارئاً، تظليل آية متزامن مع التلاوة، بحث ذكي بتطبيع عربي كامل، يعمل دون اتصال بعد التنزيل.",
      "icon": "build/icons",
      "desktop": {
        "entry": {
          "Name": "GT-QURANREADER",
          "Name[ar]": "عارض و قارئ الذكر الحكيم",
          "GenericName": "Quran Reader",
          "GenericName[ar]": "عارض القرآن الكريم",
          "Comment": "Complete Quran reading application — 4 riwayat, 13 reciters, verse-by-verse highlighting",
          "Comment[ar]": "عارض و قارئ الذكر الحكيم — 4 روايات، 13 قارئاً، تظليل آية متزامن",
          "Keywords": "quran;islam;arabic;text;recitation;mushaf;tilawah;",
          "Categories": "Education;Languages;",
          "StartupWMClass": "GT-QURANREADER",
          "StartupNotify": "true"
        }
      }
    },
    "appImage": {
      "license": "../../LICENSE"
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils", "libatspi2.0-0", "libuuid1", "libsecret-1-0"]
    }
  }
}
